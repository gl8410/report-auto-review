# Root .dockerignore
# Note: docker-compose service build contexts are ./frontend and ./backend,
# each with their own .dockerignore. This file applies to root-context builds only.

# Version control & editor
.git
.vscode
.idea
.clinerules
.roo/

# Environment variables
.env
.env.*

# Frontend (has its own build context ./frontend with its own .dockerignore)
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/coverage/
node_modules/

# Backend (has its own build context ./backend)
backend/venv/
backend/.venv/
backend/__pycache__/
backend/uploads/
backend/static/
backend/tests/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Test & documentation data
communicate/
testdata/
knowledgedata/

# Build artifacts
dist/
build/